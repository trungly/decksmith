{
  "name": "decksmith",
  "version": "1.0.2",
  "type": "module",
  "description": "A Svelte 5 presentation framework originally inspired by Reveal.js",
  "license": "MIT",
  "main": "./src/lib/index.js",
  "module": "./src/lib/index.js",
  "types": "./src/lib/index.d.ts",
  "svelte": "./src/lib/index.js",
  "exports": {
    ".": {
      "types": "./src/lib/index.d.ts",
      "svelte": "./src/lib/index.js",
      "default": "./src/lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trungly/decksmith.git"
  },
  "bugs": {
    "url": "https://github.com/trungly/decksmith/issues"
  },
  "homepage": "https://github.com/trungly/decksmith#readme",
  "keywords": [
    "svelte",
    "svelte5",
    "presentation",
    "slides",
    "deck",
    "revealjs"
  ],
  "files": [
    "src/lib"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "bun run dev",
    "dev": "bunx --bun vite",
    "playground": "bunx --bun vite --host 127.0.0.1 --port 4173 --open",
    "test:e2e": "bunx playwright test",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "pack:check": "bun pm pack --dry-run",
    "release:check": "bun run lint && bun run pack:check",
    "release:patch": "bun run release:check && bun --eval \"import { readFileSync, writeFileSync } from 'node:fs'; const path = 'package.json'; const pkg = JSON.parse(readFileSync(path, 'utf8')); const [maj, min, patch] = pkg.version.split('.').map(Number); pkg.version = [maj, min, patch + 1].join('.'); writeFileSync(path, JSON.stringify(pkg, null, 2) + '\\\\n'); console.log('Bumped version to', pkg.version);\"",
    "release:publish": "bun run release:check && bun publish --access public",
    "prepublishOnly": "bun run lint && bun run pack:check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^15.0.4"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.28.2",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.5"
  }
}
