{
  "name": "decksmith",
  "version": "1.0.2",
  "type": "module",
  "description": "A Svelte 5 presentation framework originally inspired by Reveal.js",
  "license": "MIT",
  "main": "./src/lib/index.js",
  "module": "./src/lib/index.js",
  "types": "./src/lib/index.d.ts",
  "svelte": "./src/lib/index.js",
  "exports": {
    ".": {
      "types": "./src/lib/index.d.ts",
      "svelte": "./src/lib/index.js",
      "default": "./src/lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trungly/decksmith.git"
  },
  "bugs": {
    "url": "https://github.com/trungly/decksmith/issues"
  },
  "homepage": "https://github.com/trungly/decksmith#readme",
  "keywords": [
    "svelte",
    "svelte5",
    "presentation",
    "slides",
    "deck",
    "revealjs"
  ],
  "files": [
    "src/lib"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm run lint && npm run pack:check",
    "release:patch": "npm run release:check && npm version patch",
    "release:publish": "npm run release:check && npm publish --access public",
    "prepublishOnly": "npm run lint && npm run pack:check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^15.0.4"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.28.2",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.5"
  }
}
